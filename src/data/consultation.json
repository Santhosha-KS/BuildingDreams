    "required": true,
    "validation": {
      "minLength": 2,
      "maxLength": 100
    }
  },
  {
    "id": "f2",
    "name": "email",
    "label": "Email Address",
    "type": "email",
    "placeholder": "you@example.com",
    "required": true
  },
  {
    "id": "f3",
    "name": "phone",
    "label": "Phone Number",
    "type": "tel",
    "placeholder": "+91-XXXXX-XXXXX",
    "required": true,
    "validation": {
      "pattern": "^[+]?[0-9]{10,13}$",
      "patternMessage": "Please enter a valid phone number"
    }
  },
  {
    "id": "f4",
    "name": "city",
    "label": "Your City",
    "type": "text",
    "placeholder": "e.g. Bengaluru",
